# Local Development Environment Variables
# Copy this file to .env and fill in your actual values

# General
DEFAULT_LOGIN_PWD=c27435962ded9355cccc4017152c18f0
ROOT_PASSWORD=admin

STORAGE_CACHE_TYPE=redis

# Redis
REDIS_ADDR=127.0.0.1:6087
REDIS_USERNAME=
REDIS_PASSWORD=12345

# Database (MySQL example)
# DB_DSN=root:zhimakaimena@tcp(svc.900406.xyz:3306)/ai-gateway?charset=utf8mb4&parseTime=True&loc=Local&tls=false&timeout=5s&readTimeout=5s&writeTimeout=5s

# Database (SQLite3 - default)
DB_TYPE=sqlite3
DB_DSN=data/tokenlive-admin.db

# MySQL Connection Details (if using MySQL)
# MYSQL_PASSWORD=zhimakaimena
# MYSQL_HOST=svc.900406.xyz
# MYSQL_PORT=3306
# MYSQL_DB=ai-gateway

# Captcha (optional, uses Redis settings by default)
# CAPTCHA_REDIS_ADDR=127.0.0.1:6087
# CAPTCHA_REDIS_PASSWORD=12345

# Prometheus (optional)
PROMETHEUS_USERNAME=admin
PROMETHEUS_PASSWORD=admin

# Prometheus Server (optional)
PROMETHEUS_SERVER_URL=http://127.0.0.1:9090
PROMETHEUS_SERVER_USERNAME=admin
PROMETHEUS_SERVER_PASSWORD=123456

# Gateway Config Sync Token (Must match the gateway's GATEWAY_SYNC_TOKEN)
# GATEWAY_SYNC_TOKEN=default_tokenlive_sync_secret_token_2026

# Gateway API key hash pepper (must match tokenlive-gateway GATEWAY_API_KEY_PEPPER)
GATEWAY_API_KEY_PEPPER=

# HTTP TLS Config (optional)
# HTTP_CERT_FILE=certs/fullchain.crt
# HTTP_KEY_FILE=certs/tokenlive.net.key
